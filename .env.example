GEMINI_API_KEY=your_api_key_here

# Shared secret the desktop client must send as `X-App-Token`. Leave unset to
# keep the server open for local static/index.html testing. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
APP_AUTH_TOKEN=your_app_auth_token_here

# Optional: enables /api/me (per-user identity/plan/quota). Without these,
# /api/me returns 501 and everything else keeps working unaffected.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
